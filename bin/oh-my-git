#!/bin/sh

usage() {
    echo "Usage: oh-my-git <command>"
    echo "Any other arguments will be passed over to actual commant"
    echo 
    echo "Provided aliases:"
    echo "   gfu          git fetch upstream"
    echo "   backport     git backport"
    echo "   wb           git.workbranch"
    echo "   wip          git.wipbranch"
    echo "   gam          git commit -v --no-edit --amend"
    echo "   gama         git commit -v --no-edit --amend -a"
    echo "   glogf        git log --decorate --graph"
    echo "   glu          git pull-upstream"
    echo "   gpu          git push-upstream"
    echo "   gpo          git push-origin"
    echo "   gwip         git-wip (add all + wip commit, skip ci)"
    echo "   gcm          git-commit-msg (commit with message length check)"
    echo "   gcam         git-add-commit-msg (add all + commit with message)"
    echo "   grv          git.review"
    echo "   gu           git undo"
    echo "   gs           git.status"
    echo "   gsh          git stash"
    echo
    echo "Provided functions: (Git)"
    echo "   git.rebase.interactive   Run an interactive rebase with the last <num> commits (alias: gri)"
    echo "   git.workbranch           Create a local clone and prepare a branch. Branch name can be prefixed with env var GH_USER_PREFIX (alias: wb)"
    echo "   git.wipbranch            Create a local wip branch (alias: wip)"
    echo "   git.review               Create a local clone for reviewing a PR (alias: grv)"
    echo "   git.status               Show git status with separator (alias: gs)"
    echo "   git-wip                  Add all and commit as wip [skip ci] (alias: gwip)"
    echo "   git-commit-msg           Commit with message length warning (alias: gcm)"
    echo "   git-add-commit-msg       Add all and commit with message (alias: gcam)"
    echo "   git-show-files           Show files changed in last commit"
    echo "   git-power-status         Git status with assume-unchanged file listing"
    echo "   gls                      Power status + git log (accepts optional line count)"
    echo "   gpof                     Force push to origin (with confirmation)"
    echo "   gpuf                     Force push to upstream (with confirmation)"
    echo "   grum                     Fetch upstream and rebase on upstream/main"
    echo "   ask                      Explain a command using gh copilot"
    echo
    echo "Provided functions: (GitHub)"
    echo "   ghp            Navigate to and operate on GitHub projects (use ghp -h for options)"
    echo "   edit.current   Open current directory in editor or IntelliJ"
    echo
    echo
    echo "Git extensions:"
    echo "   assume-unchanged    Mark modified files as assume-unchanged"
    echo "   no-assume-unchanged Unmark files previously marked as assume-unchanged"
    echo "   backport            Backports cherry-picked commits between the specified branches"
    echo "   clone-fork          Forks and prepares a working copy of the provided repo"
    echo "   copy-ide-settings   Copy IntelliJ .idea settings from a sibling repo"
    echo "   current-branch      Echoes the active branch in the working repo"
    echo "   prepare             Reorganize a repo clone into the expected folder structure"
    echo "   pull-origin         Pulls the current branch from 'origin'"
    echo "   pull-upstream       Pulls the current branch from 'upstream'"
    echo "   push-upstream       Pushes the current branch to 'upstream'"
    echo "   push-origin         Pushes the current branch to 'origin'"
    echo "   recent              Print a nice summary of the recent commits (a convenient git log)"
    echo "   undo                Soft resets the branch <num> commits"
    echo "   undo-hard           Hard resets the branch <num> commits"
    echo 
    echo 
    exit $1
}

if [[ $# -eq 0 ]]; then
    usage 0
fi

while [[ $# -gt 0 ]]
do
    case $1 in
        -h|--help)
            usage 0
            ;;
        *)
            RESIDUAL_ARGS+=("$1")
            ;;
    esac
    shift
done
